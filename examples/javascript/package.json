{
  "name": "geospatial-grpc-javascript-example",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript example for Geospatial gRPC protocols",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "generate": "buf generate --template ../../buf.gen.yaml --include-imports --path ../../geospatial/v1 --output src/gen"
  },
  "keywords": [
    "grpc",
    "geospatial",
    "gis",
    "protobuf"
  ],
  "author": "Geospatial gRPC Contributors",
  "license": "Apache-2.0",
  "dependencies": {
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-node": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0"
  }
}